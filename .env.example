# HTTP listen address in host:port form.
# Use 127.0.0.1:11960 for local-only access.
BIND_ADDR=127.0.0.1:11960

# Optional when binding locally. Required when binding to non-local addresses.
# AUTH_TOKEN=

# Runtime metadata database path for sessions and build jobs. Defaults to ./data/hub.db.
# STATE_DB_PATH=./data/hub.db

# Root directory for YAML environment/image configs. Defaults to ./configs.
# CONFIG_ROOT=./configs

# Root directory for per-session rootfs directories mounted into containers at /workspace. Defaults to ./data/rootfs.
# ROOTFS_ROOT=./data/rootfs

# Root directory used for managed image builds and smoke-check temp files. Defaults to ./data/builds.
# BUILD_ROOT=./data/builds

# Container engine: auto, docker, or podman. auto searches docker first, then podman.
ENGINE=auto

# IANA timezone name for UI date/time formatting (e.g. Asia/Shanghai).
# Overrides TZ when both are set. If unset, TZ is used, then OS zoneinfo, then UTC.
# DISPLAY_TIMEZONE=

# Default timeout used when execute requests omit timeout_ms. Defaults to 30s.
# DEFAULT_COMMAND_TIMEOUT=30s

# Execute logs are not persisted by default. Enable persistence to retain
# `/executions` logs, with each stdout/stderr field capped at 65536 bytes by default.
# ENABLE_EXEC_LOG_PERSIST=true
# EXEC_LOG_MAX_OUTPUT_BYTES=65536
